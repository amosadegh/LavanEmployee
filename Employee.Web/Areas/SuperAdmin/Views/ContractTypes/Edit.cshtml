@model Employee.Entities.Models.Basic.ContractType

@{
    ViewBag.Title = "ویرایش قرارداد";
    // Layout = "~/Areas/SuperAdmin/Views/Shared/_Layout.cshtml";
}

<h1 class="h3 mb-4 text-gray-800">@ViewBag.Title</h1>


<div class="card shadow-sm">
    <div class="card-header">
        فرم @ViewBag.Title
    </div>
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ContractTypeId" />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContractTypeTitle" class="form-label">نوع قرارداد</label>
                    <input type="text" asp-for="ContractTypeTitle" class="form-control">
                    <span asp-validation-for="ContractTypeTitle" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle me-2"></i>ذخیره اطلاعات
            </button>
            <a asp-action="Index" class="btn btn-secondary">انصراف</a>

        </form>
    </div>
</div>

