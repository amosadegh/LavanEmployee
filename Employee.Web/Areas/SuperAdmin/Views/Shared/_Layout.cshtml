@using System.Configuration
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" Content="IE=edge">
    <title>@ViewBag.Title</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta Content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <link rel="stylesheet" href="~/Content/css/bootstrap-theme.css">
    <!--  My Fonts Face-->
    <link href="~/Content/css/Font-Face.css" rel="stylesheet" />
    <!-- Bootstrap rtl -->
    <link rel="stylesheet" href="~/Content/css/rtl.css">
    <!-- babakhani datepicker -->
    <link rel="stylesheet" href="~/Content/css/persian-datepicker-0.4.5.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/Content/bower_components/font-awesome/css/font-awesome.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="~/Content/bower_components/Ionicons/css/ionicons.min.css">
    <link href="~/Content/bower_components/select2/dist/css/select2.min.css" rel="stylesheet" />
    <!-- Theme style -->
    <link rel="stylesheet" href="~/Content/css/AdminLTE.css">
    <!-- AdminLTE Skins. Choose a skin from the css/skins
         folder instead of downloading all of them to reduce the load. -->
    <link rel="stylesheet" href="~/Content/css/skins/_all-skins.min.css">
    <!-- My Style-->
    <link rel="stylesheet" href="~/Content/css/MyStyle.css">
    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
    <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
    <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
    <![endif]-->
    <!-- Google Font -->
    @*<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,600,700,300italic,400italic,600italic">*@
    @RenderSection("styles", false)
</head>
<body class="skin-blue sidebar-mini" style="height: auto; min-height: 100%;">
    <div class="wrapper" style="height: auto; min-height: 100%;">

        <header class="main-header">
            <!-- Logo -->
            <a href="/Home/index" class="logo">
                <!-- mini logo for sidebar mini 50x50 pixels -->
                <span class="logo-mini">پنل</span>
                <!-- logo for regular state and mobile devices -->
                <span class="logo-lg"><b>کنترل پنل مدیریت</b></span>
            </a>
            <!-- Header Navbar: style can be found in header.less -->
            <nav class="navbar navbar-static-top">
                <!-- Sidebar toggle button-->
                <a href="#" class="sidebar-toggle" data-toggle="push-menu" role="button">
                    <span class="sr-only">Toggle navigation</span>
                </a>
                <div class="pull-right image">
                    <img src="~/Content/img/Iooc-logo.png" style="width: 80px; height: 50px;">
                </div>
                <h5 style="padding-top: 5px; color: #ffffff; font-weight: bold;">سامانه اطلاعات پرسنل پیمانکاری منطقه لاوان</h5>

            </nav>
        </header>
        <!-- right side column. contains the logo and sidebar -->
        <aside class="main-sidebar">
            <!-- sidebar: style can be found in sidebar.less -->
            <section class="sidebar">
                <!-- Sidebar user panel -->
                <div class="user-panel">
                    <div class="pull-right image">
                        <img src="~/Content/img/avatar.png" class="img-circle" alt="User Image">
                    </div>
                    <div class="pull-right info">
                        @* <p class="text-center">@User.Identity.Name</p> *@
                        <a href="#"><i class="fa fa-user text-light"></i>@* @LoginUserData.GetUserRoleTitle(User.Identity.Name).First() *@</a>
                        <a href=@Url.Action("Logoff","Account")><i class="fa fa-power-off text-light text-center fa-1x"></i>خروج</a>
                    </div>
                </div>
                <!-- search form -->
                @*<form action="#" method="get" class="sidebar-form">
                <div class="input-group">
                <input type="text" name="q" class="form-control" placeholder="جستجو">
                <span class="input-group-btn">
                <button type="submit" name="search" id="search-btn" class="btn btn-flat">
                <i class="fa fa-search"></i>
                </button>
                </span>
                </div>
                </form>*@
                <!-- /.search form -->
                <!-- sidebar menu: : style can be found in sidebar.less -->
                <ul class="sidebar-menu" data-widget="tree">
                    <li class="header" style="background-color: #222D32; color: white;border-bottom: 2px solid white"></li>
                    <li>
                        <a href=@Url.Action("Index","Home")>
                            <i class="fa fa-home"></i> <span>خانه</span>
                            @*<span class="pull-left-container">
                            <small class="label pull-left bg-green">جدید</small>
                            </span>*@
                        </a>
                    </li>
                    <li class="treeview">
                        <a href="#">
                            <i class="fa fa-user"></i> <span>مدیریت کاربران</span>
                            <span class="pull-left-container">
                                <i class="fa fa-angle-right pull-left"></i>
                            </span>
                        </a>
                        <ul class="treeview-menu">
                            @*<li class="active"><a href="../StudyLevels/Create"><i class="fa fa-circle-o"></i>افزودن مقطع تحصیلی جدید</a></li>*@
                            <li><a href=@Url.Action("Index","Roles")><i class="fa fa-circle-o"></i>انواع دسترسی</a></li>
                            <li><a href=@Url.Action("Index","Users")><i class="fa fa-circle-o"></i>کاربران</a></li>
                        </ul>
                    </li>
                    @* add active class to below treeview opend tree *@
                    <li class="treeview">
                        <a href="#">
                            <i class="fa fa-files-o"></i> <span>مقادیر پایه</span>
                            <span class="pull-left-container">
                                <i class="fa fa-angle-right pull-left"></i>
                            </span>
                        </a>
                        <ul class="treeview-menu">
                            @*<li class="active"><a href="../StudyLevels/Create"><i class="fa fa-circle-o"></i>افزودن مقطع تحصیلی جدید</a></li>*@
                            <li><a href=@Url.Action("Index","StudyLevels")><i class="fa fa-circle-o"></i>مقاطع تحصیلی</a></li>
                            <li><a href=@Url.Action("Index","StudyFields")><i class="fa fa-circle-o"></i>رشته های تحصیلی</a></li>
                            <li><a href=@Url.Action("Index","EduOrientations")><i class="fa fa-circle-o"></i>گرایش رشته های تحصیلی</a></li>
                            <li><a href=@Url.Action("Index","ContractTypes")><i class="fa fa-circle-o"></i>انواع قرارداد</a></li>
                            <li><a href=@Url.Action("Index","Jobs")><i class="fa fa-circle-o"></i>عناوین شغل ها</a></li>
                            <li><a href=@Url.Action("Index","Administrations")><i class="fa fa-circle-o"></i>مدیریت ها</a></li>
                            <li><a href=@Url.Action("Index","Organizations")><i class="fa fa-circle-o"></i>سازمان ها</a></li>
                            <li><a href=@Url.Action("Index","SecondOrganizations")><i class="fa fa-circle-o"></i>سازمان های فرعی</a></li>
                            @* <li><a href=@Url.Action("Index","Managements")><i class="fa fa-circle-o"></i> اداره ها</a></li> *@
                            @* <li><a href=@Url.Action("Index","OrganizationUnits")><i class="fa fa-circle-o"></i>واحد های سازمانی</a></li> *@
                            <li><a href=@Url.Action("Index","DocumentsTypes")><i class="fa fa-circle-o"></i>انواع مدارک پرسنلی</a></li>
                            <li><a href=@Url.Action("Index","Camps")><i class="fa fa-circle-o"></i>محل اسکان</a></li>
                            <li><a href=@Url.Action("Index","Banks")><i class="fa fa-circle-o"></i>بانک</a></li>
                            <li><a href=@Url.Action("Index","JobTypes")><i class="fa fa-circle-o"></i>نوع کار</a></li>
                            <li><a href=@Url.Action("Index","JobLocations")><i class="fa fa-circle-o"></i>محل خدمت</a></li>
                            <li><a href=@Url.Action("Index","Provinces")><i class="fa fa-circle-o"></i>استان ها</a></li>
                            <li><a href=@Url.Action("Index","Cities")><i class="fa fa-circle-o"></i>شهرها</a></li>
                        </ul>
                    </li>
                    <li class="treeview">
                        <a href="#">
                            <i class="fa fa-users"></i>
                            <span>اطلاعات پرسنلی</span>
                            @*<span class="pull-left-container">
                            <span class="label label-primary pull-left">4</span>
                            </span>*@
                            <span class="pull-left-container">
                                <i class="fa fa-angle-right pull-left"></i>
                            </span>
                        </a>
                        <ul class="treeview-menu">
                            <li><a href=@Url.Action("Create","PersonelTs")><i class="fa fa-circle-o"></i>افزودن پرسنل جدید</a></li>
                            <li><a href=@Url.Action("Index","PersonelTs")><i class="fa fa-circle-o"></i>لیست پرسنل</a></li>
                            <li><a href="pages/layout/fixed.html"><i class="fa fa-circle-o"></i> جستجوی پرسنل</a></li>
                        </ul>
                    </li>

                    <li class="treeview">
                        <a href="#">
                            <i class="fa fa-bar-chart-o"></i>
                            <span>گزارش</span>
                            @*<span class="pull-left-container">
                            <span class="label label-primary pull-left">4</span>
                            </span>*@
                            <span class="pull-left-container">
                                <i class="fa fa-angle-right pull-left"></i>
                            </span>
                        </a>
                        <ul class="treeview-menu">
                            <li><a href="/PersonelTs/Create"><i class="fa fa-circle-o"></i>نفرات بومی</a></li>
                            <li><a href="/PersonelTs/Index"><i class="fa fa-circle-o"></i>شرکت پیمانکاری</a></li>
                            <li><a href="pages/layout/fixed.html"><i class="fa fa-circle-o"></i> شماره قرارداد</a></li>
                            <li><a href="pages/layout/fixed.html"><i class="fa fa-circle-o"></i> تحصیلات</a></li>
                            <li><a href="pages/layout/fixed.html"><i class="fa fa-circle-o"></i> عنوان شغل</a></li>
                            <li><a href="pages/layout/fixed.html"><i class="fa fa-circle-o"></i> پرسنل سکو</a></li>
                            <li><a href="pages/layout/fixed.html"><i class="fa fa-circle-o"></i> پرسنل نوبتکار</a></li>
                            <li><a href="pages/layout/fixed.html"><i class="fa fa-circle-o"></i> محل خدمت</a></li>
                        </ul>
                    </li>

                </ul>
            </section>
            <!-- /.sidebar -->
        </aside>

        <!-- /Content Wrapper. Contains page /Content -->
        <div class="content-wrapper" style="min-height: 916.3px;">
            @RenderBody()
        </div>
        <!-- /./Content-wrapper -->
        <footer class="main-footer text-left">
            <strong>Copyright &copy; 1397 <a href="http://hipco.ir">Ahmad Mosadegh</a></strong>
        </footer>

        <!-- Add the sidebar's background. This div must be placed
         immediately after the control sidebar -->
        <div class="control-sidebar-bg"></div>
    </div>
    <!-- ./wrapper -->
    <!-- jQuery 3 -->
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <!-- AdminLTE App -->
    <script src="~/Content/js/adminlte.min.js"></script>
    <!-- AdminLTE for demo purposes -->
    <script src="~/Content/js/demo.js"></script>
    @RenderSection("scripts", false)
</body>
</html>