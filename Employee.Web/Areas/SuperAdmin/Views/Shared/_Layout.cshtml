<!doctype html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>داشبورد | پنل مدیریت مدرن</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
          rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- ** Modern Custom CSS ** -->
    <link rel="stylesheet" href="~/assets/css/style.css" />
    @RenderSection("styles", false)

</head>
<body>
    <div id="main-wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="d-flex flex-column">
            <a asp-controller="Home" asp-action="Index" asp-area="SuperAdmin" class="sidebar-brand d-flex align-items-center">
                <i class="bi bi-hexagon-fill me-2"></i>
                <span class="fw-bold">پنل ادمین</span>
            </a>

            <ul class="nav nav-pills flex-column mb-auto sidebar-nav mt-4">
                <!-- داشبورد -->
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" asp-area="SuperAdmin" class="nav-link" aria-current="page">
                        <i class="bi bi-grid-1x2-fill me-2"></i>
                        <span>داشبورد</span>
                    </a>
                </li>

                <!-- زیرمنوی اول: مقادیر پایه (آی‌دی اصلاح شده به submenuBaseValues) -->
                <li class="nav-item">
                    <a class="nav-link collapsed"
                       data-bs-toggle="collapse"
                       href="#submenuBaseValues"
                       role="button"
                       aria-expanded="false"
                       aria-controls="submenuBaseValues">
                        <i class="bi bi-layers me-2"></i>
                        <span>مقادیر پایه</span>
                        <!-- فلش راهنما که با باز شدن منو می‌چرخد -->
                        <i class="bi bi-chevron-left ms-auto submenu-arrow"></i>
                    </a>
                    <div class="collapse submenu-list-wrapper" id="submenuBaseValues">
                        <ul class="nav flex-column submenu-list">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="StudyLevels" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>مقاطع تحصیلی</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="StudyFields" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>رشته های تحصیلی</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="EduOrientations" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>گرایش رشته های تحصیلی</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="ContractTypes" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>انواع قرارداد</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Jobs" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>عناوین مشاغل</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Administrations" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>مدیریت ها</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Organizations" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>سازمان ها</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="SecondOrganizations" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>واحد سازمانی</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Camps" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>محل اسکان</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Banks" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>بانک</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="JobTypes" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>نوع کار</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="JobLocations" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>محل خدمت</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Provinces" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>استان ها</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Cities" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>شهر ها</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>

                <!-- زیرمنوی دوم: مدیریت پرسنل (آی‌دی منحصر به فرد submenuPersonnel و استفاده از تگ‌هلپرها) -->
                <li class="nav-item">
                    <a class="nav-link collapsed"
                       data-bs-toggle="collapse"
                       href="#submenuPersonnel"
                       role="button"
                       aria-expanded="false"
                       aria-controls="submenuPersonnel">
                        <i class="bi bi-people me-2"></i>
                        <span>مدیریت پرسنل</span>
                        <!-- فلش راهنما که با باز شدن منو می‌چرخد -->
                        <i class="bi bi-chevron-left ms-auto submenu-arrow"></i>
                    </a>
                    <div class="collapse submenu-list-wrapper" id="submenuPersonnel">
                        <ul class="nav flex-column submenu-list">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Personnel" asp-action="Index">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>لیست پرسنل</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="SuperAdmin" asp-controller="Personnel" asp-action="Create">
                                    <i class="bi bi-circle me-2" style="font-size: 0.5rem"></i>
                                    <span>افزودن پرسنل جدید</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>
            </ul>

            <!-- Footer Sidebar ... -->
        </nav>

        <!-- Main Content -->
        <main id="main-content">
            <!-- Top Navbar (Glassmorphism) -->
            <nav id="top-navbar" class="navbar navbar-expand">
                <button class="btn btn-light bg-transparent border-0"
                        id="sidebar-toggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="ms-auto d-flex align-items-center">
                    <span class="text-muted me-3">امروز: ۱۴۰۵/۰۴/۰۵</span>
                    <!-- بخش اعلان‌ها در هدر -->
                    <div class="dropdown">
                        <a class="nav-link position-relative dropdown-toggle no-arrow"
                           href="#"
                           role="button"
                           id="notificationDropdown"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-bell fs-5 text-muted"></i>
                            <!-- نقطه قرمز رنگ اعلان فعال (نشان‌دهنده وجود اعلان جدید) -->
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">اعلان جدید</span>
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end notification-dropdown-menu shadow border-0 py-0"
                            aria-labelledby="notificationDropdown">
                            <!-- سربرگ منوی اعلان‌ها -->
                            <li class="dropdown-header d-flex justify-content-between align-items-center py-3 border-bottom">
                                <span class="fw-bold text-dark fs-6">اعلان‌ها</span>
                                <span class="badge bg-primary-soft text-primary">$3$ اعلان جدید</span>
                            </li>

                            <!-- آیتم‌های لیست اعلان -->
                            <li>
                                <a class="dropdown-item d-flex align-items-center py-3 border-bottom"
                                   href="#">
                                    <div class="icon-circle bg-success-soft text-success me-3">
                                        <i class="bi bi-person-plus fs-5"></i>
                                    </div>
                                    <div class="w-100">
                                        <p class="mb-0 text-dark small fw-semibold">
                                            کارمند جدید ثبت نام کرد
                                        </p>
                                        <small class="text-muted d-block mt-1">$5$ دقیقه پیش</small>
                                    </div>
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center py-3 border-bottom"
                                   href="#">
                                    <div class="icon-circle bg-warning-soft text-warning me-3">
                                        <i class="bi bi-exclamation-triangle fs-5"></i>
                                    </div>
                                    <div class="w-100">
                                        <p class="mb-0 text-dark small fw-semibold">
                                            مهلت قرارداد آقای رضایی رو به اتمام است
                                        </p>
                                        <small class="text-muted d-block mt-1">$2$ ساعت پیش</small>
                                    </div>
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center py-3 border-bottom"
                                   href="#">
                                    <div class="icon-circle bg-primary-soft text-primary me-3">
                                        <i class="bi bi-chat-dots fs-5"></i>
                                    </div>
                                    <div class="w-100">
                                        <p class="mb-0 text-dark small fw-semibold">
                                            تیکت پشتیبانی جدید دریافت شد
                                        </p>
                                        <small class="text-muted d-block mt-1">دیروز</small>
                                    </div>
                                </a>
                            </li>

                            <!-- پاورقی منو -->
                            <li>
                                <a class="dropdown-item text-center py-3 text-primary fw-semibold small"
                                   href="#">
                                    مشاهده همه اعلان‌ها
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>

            <!-- Page Content -->
            <div class="container-fluid px-0">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/script.js" ></script>
    @RenderSection("scripts", false)
   
</body>
</html>
