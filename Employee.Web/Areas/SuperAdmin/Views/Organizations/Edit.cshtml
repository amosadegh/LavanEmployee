@model Employee.Entities.Models.Basic.Organization

@{

    ViewBag.Title = "ویرایش سازمان";

}

<section class="content-header" style="padding-bottom: 25px;">

    <ol class="breadcrumb">

        <li><a href="#">مقادیر پایه</a></li>

        <li><a asp-action="Index" asp-controller="Organizations">لیست سازمان‌ها</a></li>

        <li class="active">ویرایش سازمان</li>

    </ol>

</section>

<div class="form-horizontal">

    <section class="content">

        <div class="row">

            <div class="col-xs-12">

                <div class="box box-primary">

                    <div class="box-header">

                        <h3 class="box-title">ویرایش سازمان</h3>

                    </div>

                    <div class="box-body">

                        <form asp-action="Edit">

                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="OrganizationId" />

                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="form-group">

                                <div class="col-md-2 text-left">

                                    <label asp-for="OrganizationTitle" class="control-label"></label>

                                </div>

                                <div class="col-md-6">

                                    <input asp-for="OrganizationTitle" class="form-control" />

                                    <span asp-validation-for="OrganizationTitle" class="text-danger"></span>

                                </div>

                            </div>

                            <div class="form-group">

                                <div class="col-md-offset-2 col-md-10">

                                    <button type="submit" class="btn btn-primary">ذخیره تغییرات</button>

                                    <a asp-action="Index" class="btn btn-warning">

                                        بازگشت

                                    </a>

                                </div>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </section>

</div>