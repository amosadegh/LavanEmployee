@model IEnumerable<StudyLevel>

@{
    ViewBag.Title = "لیست مقاطع تحصیلی";
    // Layout = "~/Areas/SuperAdmin/Views/Shared/_Layout.cshtml";
}
@section styles{

}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 text-gray-800">@ViewBag.Title</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>افزودن مقطع جدید
    </a>
</div>
<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive px-3">
            <table id="tblList" class="table display table-striped table-bordered table-hover table-condensed table-responsive" style="width:100%;">

                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.StudyLevelTitle)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.StudyLevelTitle)
                            </td>
                            <td>
                                <a href=@Url.Action("Edit", new {id = item.StudyLevelId}) class="btn btn-sm btn-info text-white"><i class="bi bi-pencil-square"></i></a>
                                <a href=@Url.Action("Delete", new {id = item.StudyLevelId}) class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></a>
                               @*  <a href=@Url.Action("Edit", new {id = item.StudyLevelId}) class="btn btn-sm btn-info text-white" data-toggle="tooltip" data-placement="top" title="ویرایش" }></a> |
                                <a href=@Url.Action("Delete", new {id = item.StudyLevelId}) class="btn btn-danger btn-sm fa fa-trash" data-toggle="tooltip" data-placement="top" title="حذف" }></a> *@
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>
    </div>
</div>
@section scripts{
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap5.min.js"></script>
}