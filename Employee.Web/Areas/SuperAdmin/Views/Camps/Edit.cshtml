@model Camp

@{
    ViewBag.Title = "ویرایش محل اسکان";
}

<h1 class="h3 mb-4 text-gray-800">ویرایش محل اسکان </h1>


<div class="card shadow-sm">
    <div class="card-header">
        فرم ویرایش محل اسکان 
    </div>
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CampId" />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CampTitle" class="form-label">محل اسکان</label>
                    <input type="text" asp-for="CampTitle" class="form-control">
                    <span asp-validation-for="CampTitle" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle me-2"></i>ذخیره اطلاعات
            </button>
            <a asp-action="Index" class="btn btn-secondary">انصراف</a>

        </form>
    </div>
</div>
