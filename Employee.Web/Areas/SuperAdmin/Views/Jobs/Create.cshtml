@model Job

@{
    ViewBag.Title = "شغل جدید";
}

<h1 class="h3 mb-4 text-gray-800">افزودن شغل جدید</h1>


<div class="card shadow-sm">
    <div class="card-header">
        فرم افزودن شغل جدید
    </div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="JobTitle" class="form-label">عنوان شغل</label>
                    <input type="text" asp-for="JobTitle" class="form-control">
                    <span asp-validation-for="JobTitle" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle me-2"></i>ذخیره اطلاعات
            </button>
            <a asp-action="Index" class="btn btn-secondary">انصراف</a>

        </form>
    </div>
</div>
